# Core infrastructure
DATABASE_URL=postgresql://postgres:postgres@db:5432/agentic
REDIS_URL=redis://redis:6379/0
ARTIFACTS_DIR=/shared/artifacts
WORKSPACE_DIR=/shared/workspace
DOCX_TEMPLATE_DIR=/shared/templates

# Orchestration, policy, and critic
ORCHESTRATOR_ENABLED=true
ORCHESTRATOR_RECOVER_PENDING=true
ORCHESTRATOR_RECOVER_IDLE_MS=60000
JOB_RECOVERY_ENABLED=true
EVENT_OUTBOX_ENABLED=true
EVENT_OUTBOX_BATCH_SIZE=200
EVENT_OUTBOX_POLL_S=1.0
EVENT_OUTBOX_REDIS_RETRIES=3
EVENT_OUTBOX_REDIS_RETRY_SLEEP_S=0.2
REPLAN_MAX=1
POLICY_GATE_ENABLED=false
POLICY_MODE=dev
POLICY_CONFIG_PATH=config/policy.yaml
CRITIC_ENABLED=false
CRITIC_MAX_REWORKS=2
DEV_RESUME_RENDER_ENABLED=false

# Planner and global LLM settings
PLANNER_MODE=rule_based
PLANNER_MAX_DEPTH=3
LLM_PROVIDER=mock
# Use LLM_PROVIDER=openai with OPENAI_MODEL for OpenAI and OpenAI fine-tuned model IDs.
# Use LLM_PROVIDER=openai_compatible with OPENAI_BASE_URL for custom Chat Completions endpoints.
# Use LLM_PROVIDER=gemini with GEMINI_MODEL and GEMINI_API_KEY for Gemini.
OPENAI_MODEL=gpt-5-mini
GEMINI_MODEL=gemini-2.5-flash
CHAT_ROUTER_MODEL=gpt-5-mini
CHAT_RESPONSE_MODEL=gpt-4.1-mini
CHAT_PENDING_CORRECTION_MODEL=gpt-5-nano
CHAT_RESPONSE_MODE=answer_or_handoff
CHAT_ROUTING_MODE=response_first
CHAT_PENDING_CORRECTION_MODE=llm
CHAT_ROUTING_CALIBRATOR_ENABLED=true
CHAT_ROUTING_CALIBRATOR_LIVE=false
CHAT_ROUTING_CALIBRATOR_MIN_PROBABILITY=0.65
CHAT_ROUTING_CALIBRATOR_MIN_MARGIN=0.08
OPENAI_BASE_URL=https://api.openai.com
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_TEMPERATURE=
OPENAI_MAX_OUTPUT_TOKENS=
OPENAI_TIMEOUT_S=60
OPENAI_MAX_RETRIES=2

# Worker settings
WORKER_MODE=llm
WORKER_GROUP=workers
WORKER_CONSUMER=
WORKER_READ_COUNT=1
WORKER_BLOCK_MS=1000
WORKER_RECOVER_PENDING=true
WORKER_RECOVER_IDLE_MS=60000
WORKER_RECOVER_INTERVAL_S=10
WORKER_RECOVER_COUNT=10
WORKER_RETRY_ENABLED=true
WORKER_RETRY_POLICY=transient
WORKER_DEFAULT_MAX_ATTEMPTS=3
WORKER_DLQ_ENABLED=true

# Memory settings
MEMORY_API_URL=http://api:8000
MEMORY_READ_ENABLED=true
MEMORY_WRITE_ENABLED=true
SEMANTIC_MEMORY_DEFAULT_USER_ID=default-user
SEMANTIC_MEMORY_AUTO_WRITE_ENABLED=true
SEMANTIC_MEMORY_AUTO_WRITE_TOOLS=llm.text.generate,document.spec.generate,document.spec.improve,document.spec.generate_iterative,llm_generate,llm_generate_document_spec,llm_improve_document_spec,llm_iterative_improve_document_spec,openapi.iterative.improve
SEMANTIC_MEMORY_AUTO_WRITE_MAX_FACTS=3
SEMANTIC_MEMORY_AUTO_WRITE_MAX_FACT_CHARS=280
SEMANTIC_MEMORY_AUTO_WRITE_NAMESPACE=runtime
INTERACTION_SUMMARY_MEMORY_PERSIST=true
INTERACTION_SUMMARY_COMPACTION_ENABLED=true
INTERACTION_SUMMARY_COMPACT_EVERY_N=10
INTERACTION_SUMMARY_MAX_ITEMS=40
INTERACTION_SUMMARY_MAX_FACTS_PER_ITEM=4
INTERACTION_SUMMARY_MAX_CHARS_PER_FIELD=180
INTERACTION_SUMMARY_MAX_TOKENS=1800

# Service URLs and UI
NEXT_PUBLIC_API_URL=http://localhost:18000
NEXT_PUBLIC_DEV_TOOLS=false
CODER_API_URL=http://coder:8000
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_default
QDRANT_VECTOR_NAME=
QDRANT_TIMEOUT_S=10
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=Cosine
QDRANT_ON_DISK_PAYLOAD=true
QDRANT_CREATE_PAYLOAD_INDEXES=true
QDRANT_PAYLOAD_INDEX_FIELDS=document_id,namespace,tenant_id,user_id,workspace_id,source_uri
RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_TIMEOUT_S=15
RAG_REQUIRE_SCOPE=true
RAG_TOP_K_DEFAULT=5
RAG_TOP_K_MAX=20
RAG_WORKSPACE_ALLOWED_EXTENSIONS=.md,.txt,.rst,.json,.yaml,.yml,.toml,.py,.ts,.tsx,.js,.jsx,.css,.html,.sql,.sh
RAG_WORKSPACE_MAX_FILE_BYTES=2000000
RAG_WORKSPACE_CHUNK_SIZE_CHARS=1200
RAG_WORKSPACE_CHUNK_OVERLAP_CHARS=200
RAG_WORKSPACE_MAX_CHUNKS=200
RAG_PAYLOAD_TEXT_KEY=text
RAG_PAYLOAD_DOCUMENT_ID_KEY=document_id
RAG_PAYLOAD_SOURCE_URI_KEY=source_uri
RAG_PAYLOAD_NAMESPACE_KEY=namespace
RAG_PAYLOAD_TENANT_ID_KEY=tenant_id
RAG_PAYLOAD_USER_ID_KEY=user_id
RAG_PAYLOAD_WORKSPACE_ID_KEY=workspace_id
RESUME_TAILOR_API_URL=http://tailor:8000
CORS_ORIGINS=http://localhost:8510,http://localhost:3002,http://localhost:3000

# Tooling and schema controls
TOOL_HTTP_FETCH_ENABLED=false
TOOL_HTTP_FETCH_ALLOWLIST=
TOOL_OUTPUT_SIZE_CAP=50000
TOOL_INPUT_VALIDATION_ENABLED=true
INTENT_CLARIFICATION_ON_CREATE=false
INTENT_MIN_CONFIDENCE=0.70
INTENT_MIN_CONFIDENCE_BY_INTENT=
INTENT_MIN_CONFIDENCE_BY_RISK=
INTENT_CLARIFICATION_BLOCKING_SLOTS=intent_action,output_format,target_system,safety_constraints
CHAT_PRE_SUBMIT_BLOCKING_SLOTS=output_format,target_system,safety_constraints
INTENT_ASSESS_ENABLED=true
INTENT_ASSESS_MODE=heuristic
INTENT_ASSESS_MODEL=gpt-5-nano
INTENT_DECOMPOSE_ENABLED=true
INTENT_DECOMPOSE_MODE=heuristic
INTENT_DECOMPOSE_MODEL=gpt-4.1-mini
INTENT_CAPABILITY_TOP_K=3
INTENT_MEMORY_RETRIEVAL_ENABLED=true
INTENT_MEMORY_RETRIEVAL_LIMIT=3
INTENT_MEMORY_PERSIST_ENABLED=true
SCHEMA_REGISTRY_PATH=/app/schemas
SCHEMA_VALIDATION_STRICT=false
# Optional tool filters and plugin loading
ENABLED_TOOLS=
DISABLED_TOOLS=
PLANNER_ENABLED_TOOLS=
PLANNER_DISABLED_TOOLS=
WORKER_ENABLED_TOOLS=
WORKER_DISABLED_TOOLS=
API_ENABLED_TOOLS=
API_DISABLED_TOOLS=
TOOL_GOVERNANCE_ENABLED=true
TOOL_GOVERNANCE_MODE=enforce
TOOL_GOVERNANCE_CONFIG_PATH=/app/config/tool_governance.yaml
TOOL_PLUGIN_MODULES=
TOOL_PLUGIN_DISCOVERY_ENABLED=false
TOOL_PLUGIN_ENTRYPOINT_GROUP=awe.tools
TOOL_PLUGIN_FAIL_FAST=true
CAPABILITY_MODE=disabled
CAPABILITY_REGISTRY_PATH=/app/config/capability_registry.yaml
CAPABILITY_GOVERNANCE_ENABLED=true
CAPABILITY_GOVERNANCE_MODE=enforce
ENABLED_CAPABILITIES=
DISABLED_CAPABILITIES=
WORKER_ENABLED_CAPABILITIES=
WORKER_DISABLED_CAPABILITIES=
CAPABILITY_INPUT_VALIDATION_ENABLED=true
CAPABILITY_ENFORCE_SCHEMA_PROPERTIES=false

# Coder tuning and logging
CODING_AGENT_TIMEOUT_S=90
CODER_HTTP_TIMEOUT_S=90
CODER_LLM_MAX_RETRIES=2
CODER_LLM_RETRY_SLEEP_S=1.5
CODER_LOG_PROMPT_PREVIEW_CHARS=200
CODER_LOG_RESPONSE_PREVIEW_CHARS=200
CODER_LOG_RESPONSE_FULL=false

# Candidate resume logging (worker)
LOG_CANDIDATE_RESUME=false
LOG_CANDIDATE_RESUME_FULL=false
LOG_CANDIDATE_RESUME_PREVIEW_CHARS=200

# Tailor provider overrides
TAILOR_OPENAI_TIMEOUT_S=20
TAILOR_OPENAI_MAX_RETRIES=1

# Tailor evaluation settings
TAILOR_EVAL_MODE=llm
TAILOR_EVAL_PROVIDER=openai
TAILOR_EVAL_OPENAI_MODEL=
TAILOR_EVAL_OPENAI_BASE_URL=
TAILOR_EVAL_OPENAI_TEMPERATURE=
TAILOR_EVAL_OPENAI_MAX_OUTPUT_TOKENS=
TAILOR_EVAL_OPENAI_TIMEOUT_S=15
TAILOR_EVAL_OPENAI_MAX_RETRIES=1

# DeepEval release-gate settings
DEEPEVAL_ENABLED=false
DEEPEVAL_MODE=local
DEEPEVAL_JUDGE_PROVIDER=gemini
DEEPEVAL_JUDGE_MODEL=
DEEPEVAL_JUDGE_API_KEY=
DEEPEVAL_JUDGE_BASE_URL=
DEEPEVAL_UPLOAD_RESULTS=false
DEEPEVAL_EXPERIMENT_NAME=awe-agent-release-gate
DEEPEVAL_MIN_CHAT_SCORE=0.95
DEEPEVAL_MIN_PLANNER_SCORE=0.90
DEEPEVAL_STAGING_LIMIT=100
DEEPEVAL_STAGING_TIMEOUT_S=30

# Tailor iterative controls
TAILOR_MIN_CHANGES_PER_ITERATION=8
TAILOR_ITERATIVE_TIMEOUT_S=
TAILOR_ITERATIVE_RESERVE_S=60
TAILOR_ITERATIVE_CACHE_TTL_S=1800
TAILOR_ITERATIVE_INFLIGHT_WAIT_S=30
TAILOR_ITERATIVE_CACHE_MAX_ENTRIES=256

# MCP controls
MCP_ALLOWED_HOSTS=
MCP_TOOL_TIMEOUT_S=120
MCP_TOOL_OUTER_TIMEOUT_HEADROOM_S=15
MCP_TOOL_MAX_RETRIES=1
MCP_TOOL_RETRY_SLEEP_S=0.25
MCP_FIRST_ATTEMPT_RESERVE_S=30
MCP_TRANSPORT_TIMEOUT_S=
MCP_TOOL_ISOLATION_MODE=process
MCP_TIMEOUT_S=
MCP_SERVERS_CONFIG_PATH=/app/config/mcp_servers.yaml
MCP_ROUTE_PATHS=/mcp/rpc/mcp
MCP_AUTH_BEARER=
MCP_AUTH_BEARER_ENV=
MCP_EXTRA_HEADERS_JSON=

# Document store settings
DOCUMENT_STORE_BACKEND=filesystem
DOCUMENT_STORE_S3_BUCKET=
DOCUMENT_STORE_S3_PREFIX=document-store
DOCUMENT_STORE_S3_ENDPOINT=
DOCUMENT_STORE_S3_REGION=us-east-1

# Observability and metadata tags
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
PROMPT_VERSION=unknown
POLICY_VERSION=unknown
TOOL_VERSION=unknown

# Image build/push helpers
IMAGE_REGISTRY=ghcr.io
IMAGE_OWNER=
IMAGE_TAG=latest

# GitHub API settings (non-secret)
GITHUB_API_URL=https://api.github.com

# Optional one-off script value
CORRELATION_ID=

# Secrets (set locally; never commit real values)
OPENAI_API_KEY=
GEMINI_API_KEY=
TAILOR_EVAL_OPENAI_API_KEY=
GITHUB_CLASSIC_TOKEN=
GITHUB_TOKEN=
QDRANT_API_KEY=
RAG_RETRIEVER_MCP_TOKEN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
