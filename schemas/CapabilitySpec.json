{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapabilitySpec",
  "type": "object",
  "properties": {
    "id": {"type": "string"},
    "description": {"type": "string"},
    "risk_tier": {
      "type": "string",
      "enum": ["read_only", "bounded_write", "high_risk"]
    },
    "idempotency": {
      "type": "string",
      "enum": ["read", "safe_write", "unsafe_write"]
    },
    "group": {"type": "string"},
    "subgroup": {"type": "string"},
    "input_schema_ref": {"type": "string"},
    "output_schema_ref": {"type": "string"},
    "enabled": {"type": "boolean"},
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "adapters": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {"type": "string", "enum": ["mcp", "tool"]},
          "server_id": {"type": "string"},
          "tool_name": {"type": "string"},
          "route_paths": {
            "type": "array",
            "items": {"type": "string"}
          },
          "timeout_s": {"type": "number"},
          "max_retries": {"type": "integer", "minimum": 0},
          "retry_sleep_s": {"type": "number", "minimum": 0},
          "arg_map": {"type": "object"},
          "response_path": {"type": "string"},
          "enabled": {"type": "boolean"}
        },
        "required": ["type", "server_id", "tool_name"],
        "additionalProperties": true
      }
    }
  },
  "required": ["id", "description", "adapters"],
  "additionalProperties": true
}
