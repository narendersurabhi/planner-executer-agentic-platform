{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RagRerankCapabilityInput",
  "type": "object",
  "properties": {
    "query": {
      "type": "string",
      "minLength": 1
    },
    "matches": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "object",
        "properties": {
          "chunk_id": {
            "type": "string"
          },
          "document_id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "score": {
            "type": "number"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "source_uri": {
            "type": "string"
          }
        },
        "required": [
          "chunk_id",
          "document_id",
          "text",
          "score",
          "metadata",
          "source_uri"
        ],
        "additionalProperties": true
      }
    },
    "top_k": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    }
  },
  "required": [
    "query",
    "matches"
  ],
  "additionalProperties": false
}
