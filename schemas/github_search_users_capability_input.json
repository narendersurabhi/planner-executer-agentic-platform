{
  "$id": "github_search_users_capability_input",
  "title": "GitHub Search Users Capability Input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "query": {
      "type": "string",
      "description": "GitHub user search query, for example: location:seattle followers:>100"
    },
    "sort": {
      "type": "string",
      "enum": [
        "followers",
        "repositories",
        "joined"
      ]
    },
    "order": {
      "type": "string",
      "enum": [
        "asc",
        "desc"
      ]
    },
    "perPage": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "page": {
      "type": "integer",
      "minimum": 1
    }
  },
  "required": [
    "query"
  ]
}
